{
  "meta": {
    "source": "sanitized-rr-homepage",
    "description": "Sanitized homepage contract derived from mrtang-pim/docs/rr/index samples. Sensitive auth, customer identifiers and third-party session material are removed.",
    "notes": [
      "Original source host and auth headers are intentionally not replayed here.",
      "Request and response shapes preserve homepage module dependencies for frontend and backend development.",
      "Price values are normalized to currency units rather than source minor-unit integers."
    ]
  },
  "contracts": [
    {
      "id": "bootstrap_loading_setting",
      "name": "Loading Setting",
      "method": "GET",
      "originalPath": "/gateway/shop-decoration-service/api/v1/open/get_loading_setting",
      "localPath": "/api/miniapp/homepage/bootstrap",
      "role": "Startup branch and applet bootstrap config",
      "request": {
        "queryKeys": ["corpId"]
      },
      "responseKeys": ["allowSwitchBranch", "autoSwitchBranchByRange", "appletCount"],
      "tags": ["homepage", "bootstrap"]
    },
    {
      "id": "contacts_config",
      "name": "Contacts Config",
      "method": "GET",
      "originalPath": "/gateway/customer-service/api/v1/config/get_contacts_config",
      "localPath": "/api/miniapp/homepage/bootstrap",
      "role": "Homepage startup dependency for contact-related toggles",
      "request": {},
      "responseKeys": ["data"],
      "tags": ["homepage", "bootstrap"]
    },
    {
      "id": "bb_auth_status",
      "name": "B2B Auth Status",
      "method": "GET",
      "originalPath": "/gateway/customer-service/api/v1/order/app/get_bb_auth_status",
      "localPath": "/api/miniapp/homepage/bootstrap",
      "role": "Homepage access status gate",
      "request": {
        "queryKeys": ["isPreAuth", "openId"]
      },
      "responseKeys": ["status"],
      "tags": ["homepage", "auth"],
      "notes": {
        "openId": "Removed from local contract and should be resolved by your own auth layer."
      }
    },
    {
      "id": "login_status",
      "name": "Login Status",
      "method": "POST",
      "originalPath": "/gateway/customer-service/api/v1/order/app/get_login_status",
      "localPath": "/api/miniapp/homepage/bootstrap",
      "role": "Homepage eligibility and order capability summary",
      "request": {
        "bodyKeys": ["contactsId", "customerId", "isDistributor"]
      },
      "responseKeys": ["contactsName", "isOrderContacts", "auditStatus", "status"],
      "tags": ["homepage", "auth"]
    },
    {
      "id": "cart_total_num",
      "name": "Cart Total Num",
      "method": "GET",
      "originalPath": "/gateway/goodsservice/api/v1/wx/cart/get_cart_tot_num",
      "localPath": "/api/miniapp/homepage/bootstrap",
      "role": "Homepage cart total snapshot",
      "request": {
        "queryKeys": ["needAllUnit"]
      },
      "responseKeys": ["data"],
      "tags": ["homepage", "cart"]
    },
    {
      "id": "shop_config_setting",
      "name": "Shop Config Setting",
      "method": "POST",
      "originalPath": "/gateway/shop-decoration-service/api/v1/shop/config/setting",
      "localPath": "/api/miniapp/homepage/settings",
      "role": "Homepage shop configuration and visual settings",
      "request": {
        "bodyKeys": []
      },
      "responseKeys": ["corpName", "nickName", "themeColor", "goodsListSettingVO", "goodsCategorySettingVO"],
      "tags": ["homepage", "settings"]
    },
    {
      "id": "goods_category_setting_detail",
      "name": "Goods Category Setting Detail",
      "method": "POST",
      "originalPath": "/gateway/shop-decoration-service/api/v1/goods/category/setting/detail",
      "localPath": "/api/miniapp/homepage/settings",
      "role": "Category page layout defaults used by homepage navigation",
      "request": {
        "bodyKeys": []
      },
      "responseKeys": ["layoutType", "defaultSort", "maxCategoryLevel"],
      "tags": ["homepage", "settings", "category"]
    },
    {
      "id": "category_list",
      "name": "Category List",
      "method": "POST",
      "originalPath": "/gateway/gateway-mall-service/api/v1/wx/goods/category_list",
      "localPath": "/api/miniapp/homepage/categories",
      "role": "Homepage quick tabs for new / hot / recommend",
      "request": {
        "bodyKeys": ["hasGoods"]
      },
      "responseKeys": ["label", "categoryType"],
      "tags": ["homepage", "category"]
    },
    {
      "id": "template_using",
      "name": "Template Using",
      "method": "POST",
      "originalPath": "/gateway/shop-decoration-service/api/v1/shop/template/using",
      "localPath": "/api/miniapp/homepage/template",
      "role": "Homepage decoration modules and page layout",
      "request": {
        "bodyKeys": []
      },
      "responseKeys": ["templateName", "pageName", "moduleList"],
      "tags": ["homepage", "template"]
    },
    {
      "id": "goods_list_new",
      "name": "New Goods List",
      "method": "POST",
      "originalPath": "/gateway/gateway-mall-service/api/v1/wx/goods/list",
      "localPath": "/api/miniapp/homepage/sections/new",
      "role": "Homepage new-arrival or new-goods card list",
      "request": {
        "bodyKeys": ["pageNum", "pageSize", "sort", "type", "isBuyLogo", "includeTagIds"]
      },
      "responseKeys": ["pageNum", "pageSize", "total", "pages", "list"],
      "tags": ["homepage", "goods", "new"]
    },
    {
      "id": "goods_list_hot",
      "name": "Hot Goods List",
      "method": "POST",
      "originalPath": "/gateway/gateway-mall-service/api/v1/wx/goods/list",
      "localPath": "/api/miniapp/homepage/sections/hot",
      "role": "Homepage hot-sale card list",
      "request": {
        "bodyKeys": ["pageNum", "pageSize", "sort", "type", "isBuyLogo"]
      },
      "responseKeys": ["pageNum", "pageSize", "total", "pages", "list"],
      "tags": ["homepage", "goods", "hot"]
    },
    {
      "id": "price_stock_batch_new",
      "name": "Price Stock Batch New",
      "method": "POST",
      "originalPath": "/gateway/goodsservice/api/v1/wx/goods/sku/list/price_stock",
      "localPath": "/api/miniapp/homepage/sections/new",
      "role": "Batch stock and multi-unit price supplement for new goods",
      "request": {
        "bodyKeys": ["goodsShowProducedDate", "needAllUnit", "itemList", "extReturnVO", "levelId"]
      },
      "responseKeys": ["skuId", "spuId", "discountAfterPrice", "qty", "displayText", "unitInfoList"],
      "tags": ["homepage", "goods", "stock", "new"]
    },
    {
      "id": "price_stock_batch_hot",
      "name": "Price Stock Batch Hot",
      "method": "POST",
      "originalPath": "/gateway/goodsservice/api/v1/wx/goods/sku/list/price_stock",
      "localPath": "/api/miniapp/homepage/sections/hot",
      "role": "Batch stock and multi-unit price supplement for hot-sale goods",
      "request": {
        "bodyKeys": ["goodsShowProducedDate", "needAllUnit", "itemList", "extReturnVO", "levelId"]
      },
      "responseKeys": ["skuId", "spuId", "discountAfterPrice", "qty", "displayText", "unitInfoList"],
      "tags": ["homepage", "goods", "stock", "hot"]
    }
  ],
