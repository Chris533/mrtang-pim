APP_ENV=production
PIM_HTTP_ADDR=0.0.0.0:8080
PIM_PUBLIC_URL=https://pim.example.com
PIM_DATA_DIR=./pb_data

PIM_API_KEY=replace-with-a-strong-api-key
PIM_SOURCE_ADMIN_EMAILS=admin@example.com
PIM_PROCUREMENT_ADMIN_EMAILS=buyer@example.com
MRTANG_PIM_ENCRYPTION_KEY=replace-with-a-long-random-secret
PIM_SUPERUSER_EMAIL=admin@example.com
PIM_SUPERUSER_PASSWORD=replace-with-a-strong-password

# snapshot: 使用仓库内 datasets；raw: 访问真实上游
MINIAPP_SOURCE_MODE=snapshot
MINIAPP_SOURCE_URL=
MINIAPP_SOURCE_TIMEOUT=20s
MINIAPP_RAW_TEMPLATE_ID=962
MINIAPP_RAW_REFERER=https://servicewechat.com/wx57f975d225fcd0bf/9/page-frame.html
MINIAPP_RAW_OPEN_ID=
MINIAPP_RAW_CONTACTS_ID=
MINIAPP_RAW_CUSTOMER_ID=
MINIAPP_RAW_IS_DISTRIBUTOR=true
MINIAPP_RAW_ASSET_BASE_URL=
MINIAPP_RAW_CONCURRENCY=4
MINIAPP_RAW_MIN_INTERVAL=300ms
MINIAPP_RAW_RETRY_MAX=2
MINIAPP_RAW_WARMUP_MIN_INTERVAL=30m
MINIAPP_RAW_WARMUP_MAX_INTERVAL=60m
MINIAPP_HOMEPAGE_SNAPSHOT=./datasets/miniapp/homepage
MINIAPP_CATEGORY_SNAPSHOT=./datasets/miniapp/category-page
MINIAPP_PRODUCT_SNAPSHOT=./datasets/miniapp/product-page
MINIAPP_CART_ORDER_SNAPSHOT=./datasets/miniapp/cart-order
MINIAPP_AUTH_ACCOUNT_ID=replace-with-an-internal-bearer-token
MINIAPP_USER_AGENT=Mozilla/5.0 (iPhone; CPU iPhone OS 17_6 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Mobile/15E148 MicroMessenger/8.0.53(0x18003537) NetType/WIFI Language/zh_CN miniProgram

SUPPLIER_CONNECTOR=file
SUPPLIER_CODE=SUP_A
SUPPLIER_FILE=./datasets/mock_supplier_products.json

IMAGE_PROCESSOR=mock
IMAGE_WEBHOOK_URL=
IMAGE_WEBHOOK_TOKEN=
ALLOW_REMOTE_IMAGE_DOWNLOADS=true
IMAGE_TIMEOUT=45s

AUTO_PROCESS_ON_INGEST=true
AUTO_SYNC_APPROVED=false
PROCESS_BATCH_SIZE=20
SYNC_BATCH_SIZE=20
DEFAULT_STOCK_ON_HAND=100
CRON_HARVEST=0 */6 * * *
CRON_PROCESS=*/10 * * * *
CRON_SYNC=*/15 * * * *

VENDURE_ADMIN_API=http://mrtang-backend:26227/admin-api
VENDURE_SHOP_API=http://mrtang-backend:26227/shop-api
VENDURE_ADMIN_TOKEN=
VENDURE_ADMIN_USERNAME=superadmin
VENDURE_ADMIN_PASSWORD=replace-with-the-backend-superadmin-password
VENDURE_CHANNEL_TOKEN=
VENDURE_LANGUAGE_CODE=zh_Hans
VENDURE_CURRENCY_CODE=CNY
VENDURE_TIMEOUT=30s
VENDURE_ASSET_TAGS=pim,supplier
VENDURE_CF_VARIANT_SUPPLIER_CODE=supplierCode
VENDURE_CF_VARIANT_SUPPLIER_COST_PRICE=supplierCostPrice
VENDURE_CF_VARIANT_CONVERSION_RATE=conversionRate
VENDURE_CF_VARIANT_SOURCE_PRODUCT_ID=sourceProductId
VENDURE_CF_VARIANT_SOURCE_TYPE=sourceType
VENDURE_CF_PRODUCT_TARGET_AUDIENCE=targetAudience
VENDURE_CF_PRODUCT_C_END_FEATURED_ASSET=cEndFeaturedAsset
